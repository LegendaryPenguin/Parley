# Parley env template — copy to .env.local and fill in.
#
# Three layers toggle independently so you can run LIVE 0G inference while
# persistence stays mock for a no-wallet demo:
#   - Compute (NPC turns + judging)  -> server-side
#   - Storage (profile/vocab/records) -> client-side (user wallet, encrypt-to-self)
#   - Chain   (anchor record hashes)  -> client-side (user wallet signs)

# Master default for anything not set below ("mock" = canned/local, no network).
OG_MODE=mock
NEXT_PUBLIC_OG_MODE=mock

# --- 0G Compute (testnet) — server-side only ---
# "live" routes every NPC turn + judge call through real 0G inference.
OG_COMPUTE_MODE=live
OG_ROUTER_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
OG_ROUTER_API_KEY=sk-...                 # from pc.testnet.0g.ai, funded via faucet.0g.ai
OG_CHAT_MODEL=qwen/qwen2.5-omni-7b       # the TEE-attested chatbot on testnet

# --- 0G Storage (testnet) — client-side ---
# Live storage SDK wiring is a TODO (§10); leave mock unless implemented.
NEXT_PUBLIC_OG_STORAGE_MODE=mock

# --- 0G Chain anchoring (Galileo testnet, chainId 16602) — client-side ---
# "live" anchors keccak256(recordHash) as a self-tx via MetaMask on scene completion.
NEXT_PUBLIC_OG_CHAIN_MODE=mock

# Public wallet address used as player identity (storage/chain signing is in-browser).
NEXT_PUBLIC_DEMO_WALLET=0x...

OG_NETWORK=testnet
